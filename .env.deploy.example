# 复制为 .env 后按需修改：cp .env.deploy.example .env

# PostgreSQL 密码（生产请务必修改）
POSTGRES_PASSWORD=vulpass2026

# 宿主机映射端口（访问 http://<IP>:APP_PORT）
APP_PORT=8000

# ─── AI 配置（可留空，部署后在「设置」页面里配置）────────────────
# AI_PROVIDER 可选: openai / anthropic / deepseek / bailian / volcengine
AI_API_KEY=
AI_PROVIDER=
AI_BASE_URL=https://api.openai.com/v1
AI_MODEL=gpt-4o-mini
