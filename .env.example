# PostgreSQL Database
DATABASE_URL=postgresql://postgres:vulpass@localhost:5432/vuldb

# ─── AI Analysis Configuration ────────────────────────────────────────────────
# AI_API_KEY: Your API key (required for AI features)
AI_API_KEY=

# AI_PROVIDER: Preset provider (optional)
# Options: openai, anthropic, deepseek, bailian, volcengine
AI_PROVIDER=

# AI_BASE_URL / AI_MODEL: Custom endpoint (used when AI_PROVIDER is empty)
AI_BASE_URL=https://api.openai.com/v1
AI_MODEL=gpt-4o-mini

# Server
HOST=0.0.0.0
PORT=8000
