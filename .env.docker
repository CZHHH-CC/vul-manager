# Docker Environment Configuration
# Copy this to .env and modify as needed

# PostgreSQL Password (change this in production!)
POSTGRES_PASSWORD=vulpass2026

# Application Port (host side)
APP_PORT=8000

# ─── AI Analysis (optional) ──────────────────────────────────────────────────
# AI_API_KEY: Your API key
AI_API_KEY=

# AI_PROVIDER: Preset provider (simplifies configuration)
# Options: openai, anthropic, deepseek, bailian, volcengine
AI_PROVIDER=

# AI_BASE_URL / AI_MODEL: Custom endpoint (used when AI_PROVIDER is empty)
AI_BASE_URL=https://api.openai.com/v1
AI_MODEL=gpt-4o-mini

# ─── Provider Examples ───────────────────────────────────────────────────────
# OpenAI:
#   AI_PROVIDER=openai
#   AI_API_KEY=sk-xxxxx

# Anthropic Claude:
#   AI_PROVIDER=anthropic
#   AI_API_KEY=sk-ant-xxxxx

# DeepSeek:
#   AI_PROVIDER=deepseek
#   AI_API_KEY=sk-xxxxx

# 阿里云百炼:
#   AI_PROVIDER=bailian
#   AI_API_KEY=sk-xxxxx

# 火山引擎豆包:
#   AI_PROVIDER=volcengine
#   AI_API_KEY=xxxxx
